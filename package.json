{
  "name": "dse-workspace",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "test:ui": "pnpm --filter dse run test",
    "prepare": "husky && dotnet tool restore",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "spell": "cspell --quiet --no-must-find-files \"**/*.{ts,js,html,md,cs}\"",
    "lint": "pnpm --filter dse run lint",
    "lint:fix": "pnpm --filter dse run lint:fix",
    "fix": "dotnet tool restore && dotnet format Dse.slnx --no-restore --verbosity detailed --severity info && dotnet csharpier format . && pnpm --filter dse run lint:fix && prettier --write .",
    "fix:cs": "dotnet tool restore && dotnet format Dse.slnx --no-restore --verbosity detailed --severity info && dotnet csharpier format .",
    "csharpier": "dotnet csharpier format .",
    "csharpier:check": "dotnet csharpier check .",
    "ado:ci:preview": "dotnet run --file scripts/ado-preview.cs",
    "sonar:analyze": "dotnet run --file scripts/sonar-analyze.cs"
  },
  "devDependencies": {
    "cspell": "^10.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pnpm": "^11.9.0",
    "prettier": "^3.8.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3"
  }
}

<?xml version="1.0" encoding="utf-8"?>
<!-- Restore feed for `dotnet restore`/CI. The enterprise pipeline's restore tasks use
     feedsToUse: config + nugetConfigPath: nuget.config, so this file must exist for CI to resolve
     packages (the JSPS SDK, Vogen, xUnit v3, coverlet, Playwright.Xunit, ...). Mirrors the sibling
     Dse4 project, which builds in the same PNC pipeline against nuget.org. -->
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>

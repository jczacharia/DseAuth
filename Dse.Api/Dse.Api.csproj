<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" Version="10.0.9" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.9" />
  </ItemGroup>

  <!-- The Dse.UI (.esproj) owns the SPA lifecycle: `dotnet run` on it serves Angular in dev, and on
       `dotnet publish` this reference triggers its production build, which angular.json emits into
       wwwroot for the web SDK to package. ReferenceOutputAssembly=false: it produces assets, not a .dll.
       Pass -p:SkipSpaBuild=true to opt out when the SPA is built in a separate pipeline step. -->
  <ItemGroup Condition="'$(SkipSpaBuild)' != 'true'">
    <ProjectReference Include="../Dse.UI/Dse.UI.esproj">
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
    </ProjectReference>
  </ItemGroup>

</Project>
